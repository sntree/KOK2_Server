def handle_client(
    conn: socket.socket,
    addr: tuple[str, int],
    table: bytes,
    inverse_tables: list[list[int]],
) -> None:
    print("=" * 80)
    print(
        f"[{now()}] Client connected: {addr}"
    )

    # x32dbg 调试时不启用超时
    conn.settimeout(None)

    # 客户端发送方向的状态将在初始登录包解密后动态建立。
    client_state: Optional[StatefulCryptoContext] = None

    try:
        # ----------------------------------------------------
        # 初始登录包
        # ----------------------------------------------------

        initial_packet = conn.recv(4096)

        if not initial_packet:
            print(
                f"[{now()}] Client sent no initial data"
            )
            return

        dump(
            "Client initial encrypted packet",
            initial_packet,
        )

        try:
            key1, key2, initial_plain, initial_final_state = (
                decode_initial_packet(
                    packet=initial_packet,
                    inverse_tables=inverse_tables,
                )
            )

            # 后续客户端包沿用初始登录包的表行与最终滚动状态。
            client_state = StatefulCryptoContext(
                state=initial_final_state,
                table_row=key1 % 10,
            )

            print(
                f"[{now()}] Client initial keys: "
                f"key1=0x{key1:02X}, "
                f"key2=0x{key2:02X}, "
                f"table_row={key1 % 10}"
            )

            print(
                f"[{now()}] Derived follow-up crypto context: "
                f"state=0x{initial_final_state:02X}, "
                f"row=0x{key1 % 10:02X}"
            )

            dump(
                "Client initial decrypted plain",
                initial_plain,
            )

            describe_initial_login_plain(
                initial_plain
            )

        except Exception as error:
            print(
                f"[{now()}] Initial packet decode failed: "
                f"{type(error).__name__}: {error}"
            )
            print(
                f"[{now()}] Cannot derive follow-up crypto context; "
                f"closing this connection"
            )
            return

        # ----------------------------------------------------
        # 返回服务器列表
        # ----------------------------------------------------

        server_plain = build_server_list_plain()

        (
            server_encrypted,
            server_key1,
            server_key2,
            server_send_state,
        ) = encode_initial_packet_with_context(
            plain=server_plain,
            table=table,
        )

        print(
            f"[{now()}] Server-list opcode: "
            f"0x{SERVER_LIST_OPCODE:04X}"
        )

        print(
            f"[{now()}] Server-list record: "
            f"field1={SERVER_FIELD1}, "
            f"name={SERVER_NAME!r}, "
            f"field3={SERVER_FIELD3}"
        )

        dump(
            "Server-list plain",
            server_plain,
        )

        dump(
            "Server-list encrypted packet",
            server_encrypted,
        )

        conn.sendall(server_encrypted)

        print(
            f"[{now()}] Server-list packet sent"
        )


        print(
            f"[{now()}] Derived server follow-up send context: "
            f"state=0x{server_send_state.state:02X}, "
            f"row=0x{server_send_state.table_row:02X}"
        )

        print(
            f"[{now()}] Server send context is ready for the "
            f"post-selection diagnostic probe"
        )

        def login_handler_send_type4(
            opcode: int,
            data: bytes,
            label: str,
        ) -> None:
            send_type4_stateful(
                conn=conn,
                table=table,
                context=server_send_state,
                opcode=opcode,
                data=data,
                label=label,
            )

        configure_login_handlers(
            LoginHandlerRuntime(
                send_type4=login_handler_send_type4,
                role_token=OPCODE_7002_ROLE_TOKEN_STRING,
                role_list_delay_seconds=(
                    OPCODE_7002_DELAY_AFTER_9005_SECONDS
                ),
                role_count=OPCODE_7002_UINT16,
                enter_game_delay_seconds=(
                    ENTER_GAME_CHANGE_CONNECT_DELAY_SECONDS
                ),
                enter_game_status=ENTER_GAME_STATUS_UINT16,
                enter_game_ticket=ENTER_GAME_TICKET_BYTES,
                enter_game_connect_info=ENTER_GAME_CONNECT_INFO,
            )
        )

        if client_state is None:
            raise RuntimeError(
                "客户端状态式上下文尚未建立"
            )

        print(
            f"[{now()}] Stateful client decode context: "
            f"state=0x{client_state.state:02X}, "
            f"row=0x{client_state.table_row:02X}"
        )

        # ----------------------------------------------------
        # 后续客户端包
        # ----------------------------------------------------

        packet_number = 0
        parsed_frame_number = 0
        plaintext_stream = bytearray()
        redirect_sent = False
        response_0015_sent = False

        while True:
            ciphertext = conn.recv(4096)

            if not ciphertext:
                print(
                    f"[{now()}] Client disconnected"
                )
                break

            packet_number += 1

            dump(
                f"Client follow-up ciphertext "
                f"#{packet_number}",
                ciphertext,
            )

            if not ENABLE_STATEFUL_FOLLOWUP_DECODE:
                continue

            state_before = client_state.state

            try:
                plain = decode_stateful_packet(
                    ciphertext=ciphertext,
                    inverse_tables=inverse_tables,
                    context=client_state,
                )

                print(
                    f"[{now()}] Stateful decode "
                    f"#{packet_number}: "
                    f"state_before=0x{state_before:02X}, "
                    f"state_after=0x{client_state.state:02X}, "
                    f"row=0x{client_state.table_row:02X}"
                )

                dump(
                    f"Client follow-up plaintext "
                    f"#{packet_number}",
                    plain,
                )

                plaintext_stream.extend(plain)

                frames = extract_plain_frames(
                    plaintext_stream
                )

                for frame in frames:
                    parsed_frame_number += 1

                    (
                        frame_type,
                        opcode,
                        payload,
                    ) = describe_plain_frame(
                        frame=frame,
                        frame_number=parsed_frame_number,
                    )

                    LOGIN_DISPATCHER.dispatch(
                        PacketContext(
                            channel="login",
                            frame_type=frame_type,
                            opcode=opcode,
                            payload=payload,
                            peer=addr,
                        )
                    )

                    if (
                        frame_type == 1
                        and opcode == 0x9005
                    ):
                        # Stage70: the dispatcher/login handler now owns
                        # the real 0x9005 -> 0x7002 response.
                        pass

                    if (
                        frame_type == 1
                        and opcode == 0x9002
                    ):
                        # Stage71: the dispatcher/login handler now owns
                        # the real 0x9002 -> 0x7003 ChangeConnect response.
                        pass

                    if (
                        frame_type == 1
                        and opcode == 0x9003
                    ):
                        print(f"[{now()}] Confirmed opcode 0x9003 create-character request")
                        dump("Opcode 0x9003 create-character payload", payload)
                        print(
                            f"[{now()}] Stage27 does not respond to 0x9003; "
                            f"existing-role flow should avoid character creation."
                        )

                    if (
                        frame_type == 1
                        and opcode == 0x8015
                        and not response_0015_sent
                    ):
                        response_0015_data = build_response_0015_data()
                        response_0015_plain = build_type4_plain(
                            opcode=0x0015,
                            data=response_0015_data,
                        )
                        state_before_0015 = server_send_state.state
                        response_0015_encrypted = encode_stateful_packet(
                            plain=response_0015_plain,
                            table=table,
                            context=server_send_state,
                        )
                        dump("Opcode-0x0015 response plain", response_0015_plain)
                        dump("Opcode-0x0015 response encrypted", response_0015_encrypted)
                        print(
                            f"[{now()}] 0x0015 fields: "
                            f"string1={RESPONSE_0015_STRING1!r}, "
                            f"string2={RESPONSE_0015_STRING2!r}, "
                            f"uint32_a={RESPONSE_0015_UINT32_A}, "
                            f"uint16={RESPONSE_0015_UINT16}, "
                            f"uint8={RESPONSE_0015_UINT8}, "
                            f"uint32_b={RESPONSE_0015_UINT32_B}"
                        )
                        print(
                            f"[{now()}] 0x0015 send context: "
                            f"state_before=0x{state_before_0015:02X}, "
                            f"state_after=0x{server_send_state.state:02X}, "
                            f"row=0x{server_send_state.table_row:02X}"
                        )
                        conn.sendall(response_0015_encrypted)
                        response_0015_sent = True
                        print(f"[{now()}] Opcode 0x0015 test response sent")

                    if (
                        frame_type == 1
                        and opcode == 0x9006
                        and payload == b"\x00\x01"
                    ):
                        print(
                            f"[{now()}] Confirmed server-selection request"
                        )

                        if (
                            ENABLE_UNKNOWN_OPCODE_PROBE
                            and not redirect_sent
                        ):
                            redirect_data = (
                                build_redirect_response_data()
                            )
                            probe_plain = build_type4_plain(
                                opcode=PROBE_OPCODE,
                                data=redirect_data,
                            )

                            probe_state_before = (
                                server_send_state.state
                            )

                            probe_encrypted = (
                                encode_stateful_packet(
                                    plain=probe_plain,
                                    table=table,
                                    context=server_send_state,
                                )
                            )

                            dump(
                                "Opcode-0x0002 scene plain",
                                probe_plain,
                            )

                            dump(
                                "Opcode-0x0002 scene encrypted",
                                probe_encrypted,
                            )

                            print(
                                f"[{now()}] Probe send context: "
                                f"state_before="
                                f"0x{probe_state_before:02X}, "
                                f"state_after="
                                f"0x{server_send_state.state:02X}, "
                                f"row="
                                f"0x{server_send_state.table_row:02X}"
                            )

                            print(
                                f"[{now()}] Scene fields: "
                                f"field00={REDIRECT_FIELD_00}, "
                                f"host={REDIRECT_HOST}, "
                                f"field08={REDIRECT_FIELD_08}, "
                                f"field0A={REDIRECT_FIELD_0A}, "
                                f"field0C={REDIRECT_FIELD_0C}, "
                                f"field10={REDIRECT_FIELD_10}, "
                                f"field14={REDIRECT_FIELD_14}"
                            )

                            conn.sendall(probe_encrypted)
                            redirect_sent = True

                            print(
                                f"[{now()}] Opcode "
                                f"0x{PROBE_OPCODE:04X} "
                                f"scene response sent"
                            )

                            if ENABLE_OPCODE_7003_PROBE:
                                print(
                                    f"[{now()}] Waiting "
                                    f"{OPCODE_7003_PROBE_DELAY_SECONDS:.2f}s "
                                    f"before opcode 0x7003 probe"
                                )

                                time.sleep(
                                    OPCODE_7003_PROBE_DELAY_SECONDS
                                )

                                # 0x7003 stage18 字段：
                                #   type02 = uint16
                                #   type09 = uint32 length + raw bytes
                                #   tail   = 1 byte placeholder
                                #
                                # 完整 data 长度固定为 8：
                                #   2 + 4 + 1 + 1 = 8
                                opcode_7003_data = b"".join((
                                    OPCODE_7003_UINT16.to_bytes(2, "big"),
                                    len(OPCODE_7003_TYPE09_BYTES).to_bytes(4, "big"),
                                    OPCODE_7003_TYPE09_BYTES,
                                    OPCODE_7003_TAIL_BYTE,
                                ))

                                expected_7003_len = 8

                                if len(opcode_7003_data) != expected_7003_len:
                                    raise RuntimeError(
                                        f"opcode 0x7003 data size must be 8, "
                                        f"got {len(opcode_7003_data)}"
                                    )

                                print(
                                    f"[{now()}] Opcode 0x7003 stage18 fields: "
                                    f"u16={OPCODE_7003_UINT16}, "
                                    f"type09_len={len(OPCODE_7003_TYPE09_BYTES)}, "
                                    f"tail_len={len(OPCODE_7003_TAIL_BYTE)}, "
                                    f"data_len={len(opcode_7003_data)}"
                                )

                                send_type4_stateful(
                                    conn=conn,
                                    table=table,
                                    context=server_send_state,
                                    opcode=0x7003,
                                    data=opcode_7003_data,
                                    label="Opcode-0x7003 probe",
                                )

                                print(
                                    f"[{now()}] Opcode 0x7003 probe sent"
                                )

                                if ENABLE_OPCODE_7004_PROBE:
                                    print(
                                        f"[{now()}] Waiting "
                                        f"{OPCODE_7004_PROBE_DELAY_SECONDS:.2f}s "
                                        f"before opcode 0x7004 probe"
                                    )

                                    time.sleep(
                                        OPCODE_7004_PROBE_DELAY_SECONDS
                                    )

                                    opcode_7004_data = (
                                        OPCODE_7004_UINT16.to_bytes(2, "big")
                                    )

                                    expected_7004_len = 2

                                    if len(opcode_7004_data) != expected_7004_len:
                                        raise RuntimeError(
                                            f"opcode 0x7004 data size must be 2, "
                                            f"got {len(opcode_7004_data)}"
                                        )

                                    print(
                                        f"[{now()}] Opcode 0x7004 stage18 fields: "
                                        f"u16={OPCODE_7004_UINT16}, "
                                        f"data_len={len(opcode_7004_data)}"
                                    )

                                    send_type4_stateful(
                                        conn=conn,
                                        table=table,
                                        context=server_send_state,
                                        opcode=0x7004,
                                        data=opcode_7004_data,
                                        label="Opcode-0x7004 probe",
                                    )

                                    print(
                                        f"[{now()}] Opcode 0x7004 probe sent"
                                    )

                                    if ENABLE_OPCODE_7006_PROBE:
                                        print(
                                            f"[{now()}] Waiting "
                                            f"{OPCODE_7006_PROBE_DELAY_SECONDS:.2f}s "
                                            f"before opcode 0x7006 probe"
                                        )

                                        time.sleep(
                                            OPCODE_7006_PROBE_DELAY_SECONDS
                                        )

                                        opcode_7006_data = bytes((
                                            OPCODE_7006_UINT8 & 0xFF,
                                        ))

                                        expected_7006_len = 1

                                        if len(opcode_7006_data) != expected_7006_len:
                                            raise RuntimeError(
                                                f"opcode 0x7006 data size must be 1, "
                                                f"got {len(opcode_7006_data)}"
                                            )

                                        print(
                                            f"[{now()}] Opcode 0x7006 stage18 fields: "
                                            f"u8={OPCODE_7006_UINT8}, "
                                            f"data_len={len(opcode_7006_data)}"
                                        )

                                        send_type4_stateful(
                                            conn=conn,
                                            table=table,
                                            context=server_send_state,
                                            opcode=0x7006,
                                            data=opcode_7006_data,
                                            label="Opcode-0x7006 probe",
                                        )

                                        print(
                                            f"[{now()}] Opcode 0x7006 probe sent"
                                        )

                                        if ENABLE_OPCODE_7008_PROBE:
                                            print(
                                                f"[{now()}] Waiting "
                                                f"{OPCODE_7008_PROBE_DELAY_SECONDS:.2f}s "
                                                f"before opcode 0x7008 probe"
                                            )

                                            time.sleep(
                                                OPCODE_7008_PROBE_DELAY_SECONDS
                                            )

                                            # 0x7008 stage19 字段：
                                            #   type02 = uint16
                                            #   C string 1，空串为 00
                                            #   C string 2，空串为 00
                                            #
                                            # 预期 data length = 2 + 1 + 1 = 4。
                                            opcode_7008_data = b"".join((
                                                OPCODE_7008_UINT16.to_bytes(2, "big"),
                                                OPCODE_7008_STRING_A.encode("ascii") + b"\x00",
                                                OPCODE_7008_STRING_B.encode("ascii") + b"\x00",
                                            ))

                                            expected_7008_len = 4

                                            if len(opcode_7008_data) != expected_7008_len:
                                                raise RuntimeError(
                                                    f"opcode 0x7008 data size must be 4, "
                                                    f"got {len(opcode_7008_data)}"
                                                )

                                            print(
                                                f"[{now()}] Opcode 0x7008 stage19 fields: "
                                                f"u16={OPCODE_7008_UINT16}, "
                                                f"string_a='{OPCODE_7008_STRING_A}', "
                                                f"string_b='{OPCODE_7008_STRING_B}', "
                                                f"data_len={len(opcode_7008_data)}"
                                            )

                                            send_type4_stateful(
                                                conn=conn,
                                                table=table,
                                                context=server_send_state,
                                                opcode=0x7008,
                                                data=opcode_7008_data,
                                                label="Opcode-0x7008 probe",
                                            )

                                            print(
                                                f"[{now()}] Opcode 0x7008 probe sent"
                                            )

            except Exception as error:
                print(
                    f"[{now()}] Stateful decode failed "
                    f"#{packet_number}: "
                    f"{type(error).__name__}: {error}"
                )

    except ConnectionResetError:
        print(
            f"[{now()}] Connection reset by client"
        )

    except BrokenPipeError:
        print(
            f"[{now()}] Broken pipe"
        )

    except KeyboardInterrupt:
        raise

    except Exception as error:
        print(
            f"[{now()}] Connection error: "
            f"{type(error).__name__}: {error}"
        )

    finally:
        try:
            conn.close()
        except OSError:
            pass

        print(
            f"[{now()}] Connection closed"
        )


# ============================================================
# 主程序
# ============================================================

def main() -> None:
    # Initial load supplies the login-server role list.
    # Game state is refreshed again on every 0x9007 connection.
    load_runtime_configuration()

    table = load_crypto_table(config.GKK2_PATH)

    print(
        f"[{now()}] Building inverse crypto tables"
    )

    inverse_tables = build_inverse_tables(table)

    print(
        f"[{now()}] Inverse crypto tables ready"
    )

    # 启动时先验证状态式算法
    verify_known_stateful_vector(
        inverse_tables=inverse_tables,
    )

    print(
        f"[{now()}] Listening on "
        f"{HOST}:{PORT}"
    )

    print(
        f"[{now()}] Server-list opcode: "
        f"0x{SERVER_LIST_OPCODE:04X}"
    )

    print(
        f"[{now()}] Server name: "
        f"{SERVER_NAME}"
    )

    print(
        f"[{now()}] Known-vector test state: "
        f"0x{CLIENT_INITIAL_STATE:02X}"
    )

    print(
        f"[{now()}] Known-vector test table row: "
        f"0x{CLIENT_TABLE_ROW:02X}"
    )

    print(
        f"[{now()}] Press Ctrl+C to stop"
    )

    start_dummy_game_listeners()

    server = socket.socket(
        socket.AF_INET,
        socket.SOCK_STREAM,
    )

    server.setsockopt(
        socket.SOL_SOCKET,
        socket.SO_REUSEADDR,
        1,
    )

    server.bind((HOST, PORT))
    server.listen(20)

    try:
        while True:
            conn, addr = server.accept()

            handle_client(
                conn=conn,
                addr=addr,
                table=table,
                inverse_tables=inverse_tables,
            )

    except KeyboardInterrupt:
        print(
            f"\n[{now()}] Server stopped"
        )

    finally:
        server.close()


if __name__ == "__main__":
    main()
