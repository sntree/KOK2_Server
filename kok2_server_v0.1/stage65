def dummy_game_listener(port: int) -> None:
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        server.bind((HOST, port))
        server.listen(5)
        print(f"[{now()}] Stage52 game listener active on {HOST}:{port}")
        while True:
            conn, addr = server.accept()
            connection_control = ConnectionControl()

            print("=" * 80)
            print(f"[{now()}] GAME CONNECTION DETECTED on port {port}: {addr}")
            try:
                conn.settimeout(None)
                data = conn.recv(4096)
                if not data:
                    print(f"[{now()}] Game client disconnected before initial packet")
                    continue

                dump(f"Game-port {port} first client encrypted data", data)

                game_table = load_crypto_table(config.GKK2_PATH)
                game_inverse_tables = build_inverse_tables(game_table)

                key1, key2, plain, final_state = decode_initial_packet(
                    packet=data,
                    inverse_tables=game_inverse_tables,
                )

                game_client_state = StatefulCryptoContext(
                    state=final_state,
                    table_row=key1 % 10,
                )

                print(
                    f"[{now()}] Game-port {port} decoded initial keys: "
                    f"key1=0x{key1:02X}, key2=0x{key2:02X}, "
                    f"row=0x{key1 % 10:02X}, final_state=0x{final_state:02X}"
                )
                dump(f"Game-port {port} first client decrypted plain", plain)

                frame_type = -1
                opcode = -1
                payload = b""
                if len(plain) >= 8:
                    frame_type = int.from_bytes(plain[0:2], "big")
                    opcode = int.from_bytes(plain[2:4], "big")
                    payload_length = int.from_bytes(plain[4:8], "big")
                    payload = plain[8:8 + payload_length]
                    print(
                        f"[{now()}] Game-port {port} parsed first frame: "
                        f"type={frame_type}, opcode=0x{opcode:04X}, "
                        f"payload_length={payload_length}, total_length={len(plain)}"
                    )
                    dump(f"Game-port {port} first frame payload", payload)

                    GAME_DISPATCHER.dispatch(
                        PacketContext(
                            channel="game",
                            frame_type=frame_type,
                            opcode=opcode,
                            payload=payload,
                            peer=addr,
                            control=connection_control,
                        )
                    )

                if (
                    ENABLE_GAME_OPCODE_0002_0005_ONLY_PROBE
                    and frame_type == 1
                    and opcode == 0x9007
                ):
                    # Reload SQLite state for every new game connection.
                    reload_runtime_character_for_game_login()

                    payload_0002 = build_game_opcode_0002_payload()
                    plain_0002 = build_type1_plain(
                        opcode=GAME_OPCODE_0002,
                        payload=payload_0002,
                    )

                    encrypted_0002, send_key1, send_key2, game_server_state = (
                        encode_initial_packet_with_context(
                            plain=plain_0002,
                            table=game_table,
                        )
                    )

                    dump(f"Game-port {port} opcode 0x0002 map-init payload", payload_0002)
                    dump(f"Game-port {port} opcode 0x0002 map-init plain", plain_0002)
                    dump(f"Game-port {port} opcode 0x0002 map-init encrypted", encrypted_0002)
                    print(
                        f"[{now()}] Game-port {port} opcode 0x0002 initial send keys: "
                        f"key1=0x{send_key1:02X}, key2=0x{send_key2:02X}, "
                        f"row=0x{game_server_state.table_row:02X}, "
                        f"state=0x{game_server_state.state:02X}"
                    )
                    print(
                        f"[{now()}] Game-port {port} opcode 0x0002 fields: "
                        f"map={GAME_OPCODE_0002_MAP_NAME!r}, "
                        f"field00={GAME_OPCODE_0002_FIELD_00}, "
                        f"field08={GAME_OPCODE_0002_FIELD_08}, "
                        f"field0A={GAME_OPCODE_0002_FIELD_0A}, "
                        f"field0C={GAME_OPCODE_0002_FIELD_0C}, "
                        f"field10={GAME_OPCODE_0002_FIELD_10}, "
                        f"field14={GAME_OPCODE_0002_FIELD_14}"
                    )
                    conn.sendall(encrypted_0002)
                    print(f"[{now()}] Game-port {port} opcode 0x0002 map-init sent")

                    time.sleep(GAME_OPCODE_0002_TO_0005_DELAY_SECONDS)

                    payload_0005 = build_game_opcode_0005_payload()
                    plain_0005 = build_type1_plain(
                        opcode=GAME_OPCODE_0005,
                        payload=payload_0005,
                    )

                    state_before_0005 = game_server_state.state
                    encrypted_0005 = encode_stateful_packet(
                        plain=plain_0005,
                        table=game_table,
                        context=game_server_state,
                    )

                    dump(f"Game-port {port} opcode 0x0005 probe payload", payload_0005)
                    dump(f"Game-port {port} opcode 0x0005 probe plain", plain_0005)
                    dump(f"Game-port {port} opcode 0x0005 probe encrypted", encrypted_0005)
                    print(
                        f"[{now()}] Game-port {port} opcode 0x0005 stateful send: "
                        f"state_before=0x{state_before_0005:02X}, "
                        f"state_after=0x{game_server_state.state:02X}, "
                        f"row=0x{game_server_state.table_row:02X}"
                    )
                    print(
                        f"[{now()}] Game-port {port} opcode 0x0005 fields: "
                        f"name={GAME_OPCODE_0005_NAME!r}, "
                        f"array1_count={len(GAME_OPCODE_0005_ARRAY1)}, "
                        f"array2_count={len(GAME_OPCODE_0005_ARRAY2)}"
                    )
                    conn.sendall(encrypted_0005)
                    print(f"[{now()}] Game-port {port} opcode 0x0005 probe sent")

                    print(
                        f"[{now()}] Game-port {port} opcode 0x0002 then 0x0005 probes "
                        f"sent; 0x0007 intentionally disabled; connection remains open"
                    )

                    conn.settimeout(GAME_POST_REPLY_RECV_TIMEOUT_SECONDS)
                    print(
                        f"[{now()}] Game-port {port} waiting indefinitely for "
                        f"client follow-up or disconnect"
                    )
                    followup_number = 0
                    followup_stream = bytearray()

                    while True:
                        try:
                            followup_cipher = conn.recv(4096)
                        except socket.timeout:
                            print(
                                f"[{now()}] Game-port {port} unexpected receive timeout"
                            )
                            continue

                        if not followup_cipher:
                            print(
                                f"[{now()}] Game-port {port} client disconnected "
                                f"after opcode 0x0002/0x0005/0x0007 probes"
                            )
                            break

                        followup_number += 1
                        dump(
                            f"Game-port {port} follow-up encrypted #{followup_number}",
                            followup_cipher,
                        )

                        state_before = game_client_state.state
                        followup_plain = decode_stateful_packet(
                            ciphertext=followup_cipher,
                            inverse_tables=game_inverse_tables,
                            context=game_client_state,
                        )
                        print(
                            f"[{now()}] Game-port {port} follow-up decode "
                            f"#{followup_number}: state_before=0x{state_before:02X}, "
                            f"state_after=0x{game_client_state.state:02X}, "
                            f"row=0x{game_client_state.table_row:02X}"
                        )
                        dump(
                            f"Game-port {port} follow-up plain #{followup_number}",
                            followup_plain,
                        )

                        followup_stream.extend(followup_plain)
                        frames = extract_plain_frames(followup_stream)
                        for frame_number, frame in enumerate(frames, start=1):
                            (
                                followup_frame_type,
                                followup_opcode,
                                followup_payload,
                            ) = describe_plain_frame(
                                frame=frame,
                                frame_number=frame_number,
                            )

                            GAME_DISPATCHER.dispatch(
                                PacketContext(
                                    channel="game",
                                    frame_type=followup_frame_type,
                                    opcode=followup_opcode,
                                    payload=followup_payload,
                                    peer=addr,
                                    control=connection_control,
                                )
                            )

                            if connection_control.close_requested:
                                print(
                                    f"[{now()}] Game-port {port} close requested: "
                                    f"{connection_control.close_reason}"
                                )
                                break

                        if connection_control.close_requested:
                            try:
                                conn.shutdown(socket.SHUT_RDWR)
                                print(
                                    f"[{now()}] Game-port {port} socket shutdown "
                                    "completed for normal quit"
                                )
                            except OSError as error:
                                print(
                                    f"[{now()}] Game-port {port} socket shutdown "
                                    f"warning: {error}"
                                )
                            break
                else:
                    print(
                        f"[{now()}] Game-port {port} first frame is not "
                        f"type=1 opcode=0x9007; no probe sent"
                    )

            except Exception as error:
                print(
                    f"[{now()}] Game listener {port} connection error: "
                    f"{type(error).__name__}: {error}"
                )
            finally:
                try:
                    conn.close()
                except OSError:
                    pass
                if connection_control.close_requested:
                    print(
                        f"[{now()}] Game-port {port} connection closed after "
                        "normal client quit"
                    )
                else:
                    print(f"[{now()}] Game-port {port} connection closed")
    except Exception as error:
        print(
            f"[{now()}] Game listener {port} failed: "
            f"{type(error).__name__}: {error}"
        )
    finally:
        server.close()


def start_dummy_game_listeners() -> None:
    for port in DUMMY_GAME_PORTS:
