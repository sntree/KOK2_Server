def build_game_opcode_0002_payload() -> bytes:
    """Build one map-initialization record for game opcode 0x0002."""
    return b"".join(
        [
            GAME_OPCODE_0002_FIELD_00.to_bytes(4, "big"),
            c_string(GAME_OPCODE_0002_MAP_NAME),
            GAME_OPCODE_0002_FIELD_08.to_bytes(2, "big"),
