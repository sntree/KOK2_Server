def send_type4_stateful(
    conn: socket.socket,
    table: bytes,
    context: StatefulCryptoContext,
    opcode: int,
    data: bytes,
    label: str = "Server opcode",
) -> None:
    """
    使用服务器发送方向的状态式上下文发送 type 4 frame。

    type 4 明文格式：
        00 04
        payload_length，4 字节大端，包含 opcode 两字节
        opcode，2 字节大端
        data
    """

    state_before = context.state

    plain = build_type4_plain(
        opcode=opcode,
        data=data,
    )

    encrypted = encode_stateful_packet(
        plain=plain,
        table=table,
        context=context,
    )

    dump(
        f"{label} 0x{opcode:04X} plain",
        plain,
    )

    dump(
        f"{label} 0x{opcode:04X} encrypted",
        encrypted,
    )

    print(
        f"[{now()}] {label} 0x{opcode:04X} send context: "
        f"state_before=0x{state_before:02X}, "
        f"state_after=0x{context.state:02X}, "
        f"row=0x{context.table_row:02X}"
    )

    conn.sendall(encrypted)


def build_server_list_plain() -> bytes:
    """
    构造 0x7009 服务器列表项：

        uint16
        C string
        uint16
    """

    name_bytes = (
        SERVER_NAME.encode(
            "ascii",
            errors="strict",
        )
        + b"\x00"
    )

    record = (
        SERVER_FIELD1.to_bytes(2, "big")
        + name_bytes
        + SERVER_FIELD3.to_bytes(2, "big")
    )

    return build_type4_plain(
        opcode=SERVER_LIST_OPCODE,
        data=record,
    )



def build_response_0015_data() -> bytes:
    string1 = RESPONSE_0015_STRING1.encode("ascii", errors="strict") + b"\x00"
    string2 = RESPONSE_0015_STRING2.encode("ascii", errors="strict") + b"\x00"
    return (
        string1
        + string2
        + RESPONSE_0015_UINT32_A.to_bytes(4, "big")
        + RESPONSE_0015_UINT16.to_bytes(2, "big")
        + RESPONSE_0015_UINT8.to_bytes(1, "big")
        + RESPONSE_0015_UINT32_B.to_bytes(4, "big")
    )


