            GAME_OPCODE_0002_FIELD_14.to_bytes(4, "big"),
        ]
    )


def build_game_opcode_0005_payload() -> bytes:
    def u32_array(values: tuple[int, ...]) -> bytes:
        return (
            len(values).to_bytes(4, "big")
            + b"".join(value.to_bytes(4, "big") for value in values)
        )

    payload = b"".join((
        c_string(GAME_OPCODE_0005_NAME),
        c_string(GAME_OPCODE_0005_STRING1),
        c_string(GAME_OPCODE_0005_STRING2),
        GAME_OPCODE_0005_FIELD_0C.to_bytes(1, "big"),
        GAME_OPCODE_0005_FIELD_10.to_bytes(4, "big"),
        GAME_OPCODE_0005_FIELD_14.to_bytes(4, "big"),
        GAME_OPCODE_0005_FIELD_18.to_bytes(1, "big"),
        GAME_OPCODE_0005_FIELD_1A.to_bytes(2, "big"),
        GAME_OPCODE_0005_FIELD_1C.to_bytes(4, "big"),
        GAME_OPCODE_0005_FIELD_20.to_bytes(1, "big"),
        u32_array(GAME_OPCODE_0005_ARRAY1),
        GAME_OPCODE_0005_FIELD_2C.to_bytes(1, "big"),
        u32_array(GAME_OPCODE_0005_ARRAY2),
    ))
    return payload



