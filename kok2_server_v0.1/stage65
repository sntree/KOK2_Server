def pack_grid_position(x: int, y: int) -> int:
    """Pack two unsigned 16-bit grid coordinates into one uint32."""
    if not 0 <= x <= 0xFFFF:
        raise ValueError(f"GAME_SPAWN_X must be between 0 and 65535, got {x}")
    if not 0 <= y <= 0xFFFF:
        raise ValueError(f"GAME_SPAWN_Y must be between 0 and 65535, got {y}")
    return (x << 16) | y


